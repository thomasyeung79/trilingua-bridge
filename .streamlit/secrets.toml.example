# Streamlit secrets template.
#
# Local development:
#   Copy this file to .streamlit/secrets.toml and fill in the values.
#   .streamlit/secrets.toml is gitignored — never commit it.
#
# Streamlit Cloud:
#   Paste these key/value pairs into App settings → Secrets in the dashboard.

# --- AI providers (at least one required; the app auto-falls-back) ---
OPENAI_API_KEY = ""
DEEPSEEK_API_KEY = ""
ANTHROPIC_API_KEY = ""

# --- Provider routing (optional) ---
# AI_PROVIDER  = "auto"          # auto | openai | deepseek | anthropic
# OPENAI_MODEL = "gpt-4o-mini"
# DEEPSEEK_MODEL = "deepseek-chat"
# ANTHROPIC_MODEL = "claude-sonnet-4-20250514"

# --- Deployment ---
# Set DEPLOY_MODE = "demo" to enable the in-app banner explaining
# that data resets on app restart. Recommended on Streamlit Cloud.
# DEPLOY_MODE = "demo"

# --- Storage (optional) ---
# DB_PATH = "trilingua_bridge.db"

# =========================
# AI Provider
# =========================
# Options:
# - auto: OpenAI first, Anthropic fallback, DeepSeek fallback
# - openai: OpenAI only
# - deepseek: DeepSeek only
# - anthropic: Anthropic Claude only
# AI_PROVIDER=auto

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=your_openai_api_key_here

# Optional
OPENAI_MODEL=gpt-4o-mini

# Audio
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_STT_MODEL=whisper-1

# =========================
# Anthropic Claude
# =========================
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =========================
# DeepSeek
# =========================
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional
DEEPSEEK_MODEL=deepseek-chat

# =========================
# Database
# =========================
# DB_PATH has higher priority than TRILINGUA_DB_PATH.
DB_PATH=trilingua_bridge.db

# Optional alternative variable name
# TRILINGUA_DB_PATH=trilingua_bridge.db

# =========================
# Optional Proxy
# =========================
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# =========================
# Streamlit
# =========================
STREAMLIT_SERVER_PORT=8501

# =========================
# Deployment
# =========================
# DEPLOY_MODE=demo

# =========================
# Error Monitoring (optional)
# =========================
# Set SENTRY_DSN to enable Sentry error tracking for production.
# Without this, the app runs normally — no errors are captured.
# SENTRY_DSN=https://your-dsn@sentry.io/123456

# =========================
# PostgreSQL / Supabase (optional)
# =========================
# Set USE_POSTGRES=true to use Supabase PostgreSQL instead of local SQLite.
# Requires psycopg2-binary (in requirements.txt).
# USE_POSTGRES=false
# SUPABASE_DB_HOST=db.yourproject.supabase.co
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=your_password
# SUPABASE_DB_PORT=5432

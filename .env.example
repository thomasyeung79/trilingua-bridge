# =========================
# AI Provider
# =========================
# Options:
# - auto: OpenAI first, DeepSeek fallback
# - openai: OpenAI only
# - deepseek: DeepSeek only
AI_PROVIDER=auto

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=your_openai_api_key_here

# Optional
OPENAI_MODEL=gpt-4o-mini

# Audio
# Optional
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_STT_MODEL=whisper-1

# =========================
# DeepSeek
# =========================
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Optional
DEEPSEEK_MODEL=deepseek-chat

# =========================
# Database
# =========================
# DB_PATH has higher priority than TRILINGUA_DB_PATH.
DB_PATH=trilingua_bridge.db

# Optional alternative variable name
# TRILINGUA_DB_PATH=trilingua_bridge.db

# =========================
# Optional Proxy
# =========================
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# =========================
# Streamlit
# =========================
STREAMLIT_SERVER_PORT=8501
